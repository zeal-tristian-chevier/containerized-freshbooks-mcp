# --- Secrets ---
# Each secret can be provided inline here, OR (preferred) from a mounted file
# via the matching *_FILE variable, which takes precedence. Docker Compose
# wires the *_FILE vars to /run/secrets/* — see docker-compose.yml + ./secrets/.
#
# FreshBooks OAuth app credentials (https://my.freshbooks.com -> Developer)
FRESHBOOKS_CLIENT_ID=
FRESHBOOKS_CLIENT_SECRET=
# FRESHBOOKS_CLIENT_ID_FILE=/run/secrets/fb_client_id
# FRESHBOOKS_CLIENT_SECRET_FILE=/run/secrets/fb_client_secret

FRESHBOOKS_REDIRECT_URI=https://localhost/callback

# Optional — auto-discovered via /auth/api/v1/users/me if left blank
FRESHBOOKS_BUSINESS_ID=
FRESHBOOKS_IDENTITY_ID=

# Token storage backend: "keyring" (default) or "file"
FRESHBOOKS_TOKEN_BACKEND=keyring
# Only used when backend=file. Path to the encrypted token file.
FRESHBOOKS_TOKEN_PATH=
# Fernet key for the encrypted-file backend (base64, 32 bytes url-safe).
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FRESHBOOKS_TOKEN_KEY=
# Or read the key from a file (preferred — deliver as a Docker/K8s secret).
# Takes precedence over FRESHBOOKS_TOKEN_KEY.
# FRESHBOOKS_TOKEN_KEY_FILE=/run/secrets/fb_token_key

# Behavior
TZ=America/Toronto
DEFAULT_DAILY_HOURS=8
# Default local start-of-day for logged entries (HH:MM, 24h)
DEFAULT_START_TIME=09:00
# Max weekdays a single log_time call may write (abuse guard)
MAX_LOG_DAYS=31

# ── Call Processor ────────────────────────────────────────────────────────────
# Whisper model size: tiny (fastest) | base (recommended) | small | medium
WHISPER_MODEL=base

# Your email — receives a summary after every call is processed
NOTIFY_EMAIL=

# Steve's email — receives task/follow-up reminders assigned to him
EMPLOYEE_EMAIL=

# Gmail SMTP (use an App Password, not your regular Gmail password)
# Get one at: myaccount.google.com -> Security -> App Passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
