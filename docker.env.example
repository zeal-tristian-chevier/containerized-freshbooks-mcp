# Docker-specific paths — copy this to docker.env and edit before first run.
# This is the ONLY file that differs between Windows and macOS.
# docker.env is gitignored (it has local paths). This example file IS committed.

# ── Windows ───────────────────────────────────────────────────────────────────
# Replace "YourUsername" with your actual Windows username (run: echo %USERNAME%)
CLAUDE_CONFIG_DIR=C:\Users\YourUsername\.claude
CLAUDE_JSON_FILE=C:\Users\YourUsername\.claude.json

# ── macOS ─────────────────────────────────────────────────────────────────────
# Comment out the Windows lines above and uncomment these.
# Replace "yourusername" with your macOS username (run: whoami)
# CLAUDE_CONFIG_DIR=/Users/yourusername/.claude
# CLAUDE_JSON_FILE=/Users/yourusername/.claude.json
